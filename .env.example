# ── Required ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here

# ── Optional: video generation via Veo 3.1 ────────────────────
AIML_API_KEY=your_aiml_key_here

# ── Optional: OpenRouter for alternative LLMs ─────────────────
OPENROUTER_API_KEY=your_openrouter_key_here

# ── App security (auto-generated if omitted) ──────────────────
SECRET_KEY=change_this_to_a_random_secret_in_production

# ── Database path (default: data/saas.db) ────────────────────
# DATABASE_PATH=data/saas.db

# ── Debug mode ────────────────────────────────────────────────
# DEBUG=false
